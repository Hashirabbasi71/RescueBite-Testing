<?xml version="1.0" encoding="UTF-8"?>
<TestData>
    <Module name="Login">

        <!-- ═══ POSITIVE TEST CASES ═══════════════════════════════════════════ -->

        <TestCase id="LGN-001" type="positive">
            <description>Valid restaurant credentials</description>
            <email>restaurant@test.com</email>
            <password>Testpass@123</password>
            <expected>
                <redirectUrl>/dashboard</redirectUrl>
                <errorExpected>false</errorExpected>
            </expected>
        </TestCase>

        <TestCase id="LGN-002" type="positive">
            <description>Valid NGO credentials</description>
            <email>ngo@test.com</email>
            <password>Testpass@123</password>
            <expected>
                <redirectUrl>/ngo</redirectUrl>
                <errorExpected>false</errorExpected>
            </expected>
        </TestCase>

        <!-- ═══ NEGATIVE TEST CASES ════════════════════════════════════════════ -->

        <TestCase id="LGN-003" type="negative">
            <description>Wrong password for existing account</description>
            <email>restaurant@test.com</email>
            <password>wrongpassword</password>
            <expected>
                <errorMessage>Invalid login credentials</errorMessage>
                <errorExpected>true</errorExpected>
            </expected>
        </TestCase>

        <TestCase id="LGN-004" type="negative">
            <description>Unregistered email address</description>
            <email>nobody@nowhere.com</email>
            <password>Testpass@123</password>
            <expected>
                <errorMessage>Invalid login credentials</errorMessage>
                <errorExpected>true</errorExpected>
            </expected>
        </TestCase>

        <TestCase id="LGN-005" type="negative">
            <description>Correct email, completely wrong password</description>
            <email>ngo@test.com</email>
            <password>1234567890</password>
            <expected>
                <errorMessage>Invalid login credentials</errorMessage>
                <errorExpected>true</errorExpected>
            </expected>
        </TestCase>

        <!-- ═══ BOUNDARY TEST CASES ════════════════════════════════════════════ -->

        <TestCase id="LGN-006" type="boundary">
            <description>Password exactly 6 characters (minimum length)</description>
            <email>restaurant@test.com</email>
            <password>abc123</password>
            <expected>
                <errorExpected>true</errorExpected>
            </expected>
        </TestCase>

        <TestCase id="LGN-007" type="boundary">
            <description>Very long email address (100 characters)</description>
            <email>averylongemailaddressthatisexactlyonehundredcharacterslong1234567890abcde@example.com</email>
            <password>Testpass@123</password>
            <expected>
                <errorExpected>true</errorExpected>
            </expected>
        </TestCase>

        <TestCase id="LGN-008" type="boundary">
            <description>Email with leading whitespace (trimmed by app)</description>
            <email>  restaurant@test.com</email>
            <password>Testpass@123</password>
            <expected>
                <errorExpected>false</errorExpected>
            </expected>
        </TestCase>

        <!-- ═══ SECURITY TEST CASES ════════════════════════════════════════════ -->

        <TestCase id="LGN-009" type="security">
            <description>SQL injection attempt in email field</description>
            <email>' OR '1'='1'; --@test.com</email>
            <password>anything</password>
            <expected>
                <errorExpected>true</errorExpected>
                <shouldNotRedirect>true</shouldNotRedirect>
            </expected>
        </TestCase>

        <TestCase id="LGN-010" type="security">
            <description>XSS script injection in password field</description>
            <email>xss@test.com</email>
            <password>&lt;script&gt;alert('xss')&lt;/script&gt;</password>
            <expected>
                <errorExpected>true</errorExpected>
                <shouldNotRedirect>true</shouldNotRedirect>
            </expected>
        </TestCase>

        <TestCase id="LGN-011" type="security">
            <description>NoSQL injection attempt</description>
            <email>{"$gt": ""}@test.com</email>
            <password>{"$gt": ""}</password>
            <expected>
                <errorExpected>true</errorExpected>
                <shouldNotRedirect>true</shouldNotRedirect>
            </expected>
        </TestCase>

    </Module>
</TestData>
